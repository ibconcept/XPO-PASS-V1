rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isOwner(companyId) {
      return isSignedIn() && request.auth.uid == companyId;
    }

    function isStaffAuthorized(companyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/staff_authorizations/$(request.auth.token.email + "_" + companyId));
    }

    // Validation Helpers
    function isValidEvent(data) {
      return data.keys().hasAll(['name', 'company', 'location', 'companyId', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.companyId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidAttendee(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'company', 'industry', 'intent', 'type', 'eventId', 'eventLocation', 'companyId', 'createdAt']) &&
             data.keys().size() == 11 &&
             data.createdAt == request.time;
    }

    // Collections
    match /events/{eventId} {
      allow read: if true; 
      allow create: if isSignedIn() && isValidEvent(incoming());
      allow delete: if isOwner(existing().companyId);
    }

    match /attendees/{attendeeId} {
      allow create: if true; // Public registration
      allow get, list: if isOwner(resource.data.companyId) || isStaffAuthorized(resource.data.companyId);
      allow delete: if isOwner(resource.data.companyId);
    }

    match /staff_authorizations/{authId} {
      allow read: if isSignedIn();
      allow write: if isOwner(incoming().companyId) || (existing() != null && isOwner(existing().companyId));
    }
  }
}
