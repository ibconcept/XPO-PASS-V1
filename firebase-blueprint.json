{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "An event being managed by XPO-PASS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "companyId": { "type": "string", "description": "UID of the company owner" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "company", "location", "companyId"]
    },
    "Attendee": {
      "title": "Attendee",
      "description": "A person registered for an event",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "industry": { "type": "string" },
        "intent": { "type": "string" },
        "type": { "type": "string", "enum": ["VISITOR", "EXHIBITOR"] },
        "eventId": { "type": "string" },
        "eventLocation": { "type": "string" },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "eventId", "companyId"]
    },
    "StaffAuthorization": {
      "title": "Staff Authorization",
      "description": "Mapping of staff emails to companies they can manage",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "staffEmail": { "type": "string" },
        "authorized": { "type": "boolean" }
      },
      "required": ["companyId", "staffEmail", "authorized"]
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Events created by companies"
    },
    "/attendees/{attendeeId}": {
      "schema": "Attendee",
      "description": "Registered attendees"
    },
    "/staff_authorizations/{authId}": {
      "schema": "StaffAuthorization",
      "description": "Permissions for staff"
    }
  }
}
